<!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>OmniTool | Local Privacy-First Utility Suite</title>
      <script src="https://cdn.tailwindcss.com"></script>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
      <style>
          body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
          .tool-card { transition: all 0.3s ease; cursor: pointer; }
          .tool-card:hover { transform: translateY(-5px); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); border-color: #6366f1; }
          .hidden-view { display: none !important; }
      </style>
  </head>
  <body class="text-slate-900">

      <!-- Header -->
      <nav class="bg-white border-b border-slate-200 px-6 py-4 flex justify-between items-center sticky top-0 z-50">
          <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white font-bold">Ω</div>
              <span class="text-xl font-extrabold tracking-tight">OmniTool<span class="text-indigo-600">.io</span></span>
          </div>
          <div class="text-xs font-bold text-slate-400 uppercase">100% Local & Private</div>
      </nav>

      <main class="p-6 max-w-5xl mx-auto">

          <!-- Home View: Tool Selection -->
          <div id="view-home" class="view-container py-12">
              <div class="text-center mb-12">
                  <h1 class="text-4xl font-black mb-4">One Tool. Zero Servers.</h1>
                  <p class="text-slate-500 max-w-xl mx-auto">Professional utilities that process your data locally in your browser. Your files never leave your computer.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <!-- Tool 1 -->
                  <div onclick="switchView('compressor')" class="tool-card bg-white p-8 rounded-3xl border border-slate-200">
                      <div class="text-4xl mb-4">🖼️ </div>
                      <h3 class="text-xl font-bold mb-2">Image Compressor</h3>
                      <p class="text-slate-500 text-sm mb-6">Reduce image size for web without losing quality.</p>
                      <span class="text-indigo-600 font-bold text-sm">Open Tool →</span>
                  </div>
                  <!-- Tool 2 -->
                  <div onclick="switchView('pdf')" class="tool-card bg-white p-8 rounded-3xl border border-slate-200">
                      <div class="text-4xl mb-4">📄</div>
                      <h3 class="text-xl font-bold mb-2">PDF Text Extractor</h3>
                      <p class="text-slate-500 text-sm mb-6">Pull text out of PDFs instantly for easy copying.</p>
                      <span class="text-indigo-600 font-bold text-sm">Open Tool →</span>
                  </div>
                  <!-- Tool 3 -->
                  <div onclick="switchView('converter')" class="tool-card bg-white p-8 rounded-3xl border border-slate-200">
                      <div class="text-4xl mb-4">⚖️ </div>
                      <h3 class="text-xl font-bold mb-2">Unit Converter</h3>
                      <p class="text-slate-500 text-sm mb-6">Precision conversion for weight, length, and temp.</p>
                      <span class="text-indigo-600 font-bold text-sm">Open Tool →</span>
                  </div>
              </div>
          </div>

          <!-- IMAGE COMPRESSOR VIEW -->
          <div id="view-compressor" class="view-container hidden py-12">
              <button onclick="switchView('home')" class="mb-8 text-indigo-600 font-bold flex items-center gap-2">← Back to Tools</button>
              <div class="max-w-2xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-slate-200">
                  <h2 class="text-2xl font-bold mb-6">Image Compressor</h2>
                  <input type="file" id="imgInput" accept="image/*" class="block w-full text-sm text-slate-500 mb-6 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm
  file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
                  <div class="mb-6">
                      <label class="block text-sm font-medium mb-2">Quality: <span id="qVal">80</span>%</label>
                      <input type="range" id="quality" min="1" max="100" value="80" class="w-full accent-indigo-600" oninput="document.getElementById('qVal').innerText = this.value">
                  </div>
                  <button onclick="compressImage()" class="w-full py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition">Compress & Download</button>
                  <canvas id="canvas" class="hidden"></canvas>
              </div>
          </div>

          <!-- PDF EXTRACTOR VIEW -->
          <div id="view-pdf" class="view-container hidden py-12">
              <button onclick="switchView('home')" class="mb-8 text-indigo-600 font-bold flex items-center gap-2">← Back to Tools</button>
              <div class="max-w-2xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-slate-200">
                  <h2 class="text-2xl font-bold mb-6">PDF Text Extractor</h2>
                  <input type="file" id="pdfInput" accept="application/pdf" class="block w-full text-sm text-slate-500 mb-6 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm
  file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
                  <button onclick="extractPdfText()" class="w-full py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition mb-6">Extract Text</button>
                  <textarea id="pdfOutput" rows="10" class="w-full p-4 bg-slate-50 border rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500" placeholder="Extracted text will appear
  here..."></textarea>
              </div>
          </div>

          <!-- CONVERTER VIEW -->
          <div id="view-converter" class="view-container hidden py-12">
              <button onclick="switchView('home')" class="mb-8 text-indigo-600 font-bold flex items-center gap-2">← Back to Tools</button>
              <div class="max-w-xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-slate-200">
                  <h2 class="text-2xl font-bold mb-6">Unit Converter</h2>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="space-y-4">
                          <label class="block text-sm font-medium">From</label>
                          <input type="number" id="convInput" class="w-full p-3 bg-slate-50 border rounded-xl outline-none" placeholder="Value">
                          <select id="convFrom" class="w-full p-3 bg-slate-50 border rounded-xl outline-none">
                              <option value="kg">Kilograms (kg)</option>
                              <option value="lb">Pounds (lb)</option>
                              <option value="km">Kilometers (km)</option>
                              <option value="mi">Miles (mi)</option>
                              <option value="c">Celsius (°C)</option>
                              <option value="f">Fahrenheit (°F)</option>
                          </select>
                      </div>
                      <div class="space-y-4">
                          <label class="block text-sm font-medium">To</label>
                          <div id="convResult" class="p-3 bg-indigo-50 text-indigo-600 font-bold rounded-xl text-center h-[50px] flex items-center justify-center">Result</div>
                          <select id="convTo" class="w-full p-3 bg-slate-50 border rounded-xl outline-none">
                              <option value="lb">Pounds (lb)</option>
                              <option value="kg">Kilograms (kg)</option>
                              <option value="mi">Miles (mi)</option>
                              <option value="km">Kilometers (km)</option>
                              <option value="f">Fahrenheit (°F)</option>
                              <option value="c">Celsius (°C)</option>
                          </select>
                      </div>
                  </div>
                  <button onclick="convertUnits()" class="w-full mt-8 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition">Convert Now</button>
              </div>
          </div>

      </main>

      <script>
          // NAVIGATION
          function switchView(view) {
              document.querySelectorAll('.view-container').forEach(v => v.classList.add('hidden'));
              document.getElementById(`view-${view}`).classList.remove('hidden');
          }

          // TOOL 1: IMAGE COMPRESSOR
          function compressImage() {
              const input = document.getElementById('imgInput');
              if (!input.files[0]) return alert("Please select an image");

              const reader = new FileReader();
              reader.onload = function(e) {
                  const img = new Image();
                  img.onload = function() {
                      const canvas = document.getElementById('canvas');
                      const ctx = canvas.getContext('2d');
                      canvas.width = img.width;
                      canvas.height = img.height;
                      ctx.drawImage(img, 0, 0);

                      const quality = document.getElementById('quality').value / 100;
                      const dataUrl = canvas.toDataURL('image/jpeg', quality);

                      const link = document.createElement('a');
                      link.download = 'compressed-image.jpg';
                      link.href = dataUrl;
                      link.click();
                  };
                  img.src = e.target.result;
              };
              reader.readAsDataURL(input.files[0]);
          }

          // TOOL 2: PDF EXTRACTOR
          async function extractPdfText() {
              const input = document.getElementById('pdfInput');
              if (!input.files[0]) return alert("Please select a PDF");

              const file = input.files[0];
              const reader = new FileReader();
              reader.onload = async function() {
                  const typedarray = new Uint8Array(this.result);
                  const pdf = await pdfjsLib.getDocument(typedarray).promise;
                  let fullText = "";

                  for (let i = 1; i <= pdf.numPages; i++) {
                      const page = await pdf.getPage(i);
                      const textContent = await page.getTextContent();
                      fullText += textContent.items.map(s => s.str).join(" ") + "\n\n";
                  }
                  document.getElementById('pdfOutput').value = fullText;
              };
              reader.readAsArrayBuffer(file);
          }
          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

          // TOOL 3: UNIT CONVERTER
          function convertUnits() {
              const val = parseFloat(document.getElementById('convInput').value);
              const from = document.getElementById('convFrom').value;
              const to = document.getElementById('convTo').value;
              if (isNaN(val)) return alert("Enter a number");

              let result = 0;
              if (from === 'kg' && to === 'lb') result = val * 2.20462;
              else if (from === 'lb' && to === 'kg') result = val / 2.20462;
              else if (from === 'km' && to === 'mi') result = val * 0.621371;
              else if (from === 'mi' && to === 'km') result = val / 0.621371;
              else if (from === 'c' && to === 'f') result = (val * 9/5) + 32;
              else if (from === 'f' && to === 'c') result = (val - 32) * 5/9;
              else { alert("Units must be of the same type (e.g. Weight to Weight)"); return; }

              document.getElementById('convResult').innerText = result.toFixed(2);
          }
      </script>
  </body>
  </html>
